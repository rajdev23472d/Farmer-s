<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmer-s | AI Plant Disease Detection</title>

    <link rel="stylesheet" href="css/ai.css">
</head>

<body>

<header>

    <h1>🌾 Farmer-s AI</h1>

    <nav>
        <a href="dashboard.html">Dashboard</a>
        <a href="weather.html">Weather</a>
        <a href="maps.html">Maps</a>
        <a href="mandi.html">Mandi</a>
        <a href="profile.html">Profile</a>
    </nav>

</header>

<section class="ai-section">

    <h2>AI Plant Disease Detection</h2>

    <p>
        Upload a crop leaf image to detect plant diseases.
    </p>

    <div class="ai-card">

        <img
            id="preview"
            src="images/sample-leaf.jpg"
            alt="Leaf Preview"
            width="250">

        <br><br>

        <input
            type="file"
            id="imageInput"
            accept="image/*">

        <br><br>

        <button id="detectBtn">
            🔍 Detect Disease
        </button>

        <br><br>

        <h3 id="result">
            Result will appear here...
        </h3>

        <p id="confidence"></p>

        <p id="treatment"></p>

        <p id="prevention"></p>

    </div>

</section>

<footer>

    <p>
        © 2026 Farmer-s. All Rights Reserved.
    </p>

</footer>

<script src="js/ai.js"></script>

</body>
</html>
