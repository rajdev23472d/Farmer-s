/* =====================================
   Farmer-s App
   Settings CSS
   Volume 10
===================================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f5fff5;
    color:#333;
}

/* Header */

header{
    background:#2e7d32;
    color:#fff;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 30px;
    flex-wrap:wrap;
}

header h1{
    font-size:28px;
}

nav a{
    color:#fff;
    text-decoration:none;
    margin:10px;
    font-weight:bold;
}

nav a:hover{
    color:#ffeb3b;
}

/* Settings Section */

.settings{
    max-width:700px;
    margin:40px auto;
    background:#fff;
    padding:30px;
    border-radius:12px;
    box-shadow:0 5px 15px rgba(0,0,0,0.15);
}

.settings h2{
    text-align:center;
    color:#2e7d32;
    margin-bottom:25px;
}

.settings label{
    display:block;
    margin-bottom:8px;
    font-size:16px;
    color:#333;
}

.settings input[type="text"],
.settings input[type="email"],
.settings select{
    width:100%;
    padding:12px;
    border:2px solid #2e7d32;
    border-radius:8px;
    font-size:16px;
    margin-bottom:15px;
}

.settings input[type="checkbox"]{
    margin-right:8px;
    transform:scale(1.2);
}

/* Buttons */

button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:8px;
    background:#2e7d32;
    color:#fff;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
    margin-top:10px;
}

button:hover{
    background:#1b5e20;
}

/* Notification Cards */

.notification-card{
    background:#fff;
    border-left:5px solid #2e7d32;
    padding:15px;
    margin-bottom:15px;
    border-radius:8px;
    box-shadow:0 3px 8px rgba(0,0,0,0.1);
}

.notification-card h3{
    color:#2e7d32;
    margin-bottom:8px;
}

.notification-card p{
    margin-bottom:8px;
}

.notification-card small{
    color:#666;
}

/* Footer */

footer{
    background:#1b5e20;
    color:#fff;
    text-align:center;
    padding:20px;
    margin-top:40px;
}

/* Responsive */

@media(max-width:768px){

header{
    flex-direction:column;
    text-align:center;
}

nav a{
    display:block;
    margin:8px 0;
}

.settings{
    width:95%;
    margin:20px auto;
    padding:20px;
}

button{
    width:100%;
}

}
