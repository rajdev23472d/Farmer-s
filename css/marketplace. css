/* =====================================
   Farmer-s App
   Marketplace CSS
   Volume 6
===================================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f5fff5;
    color:#333;
}

/* Header */

header{
    background:#2e7d32;
    color:#fff;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 30px;
    flex-wrap:wrap;
}

header h1{
    font-size:28px;
}

nav a{
    color:#fff;
    text-decoration:none;
    margin:10px;
    font-weight:bold;
}

nav a:hover{
    color:#ffeb3b;
}

/* Marketplace */

.marketplace{
    max-width:1200px;
    margin:auto;
    padding:40px 20px;
    text-align:center;
}

.marketplace h2{
    color:#2e7d32;
    margin-bottom:20px;
}

/* Search */

#searchBox{
    width:100%;
    max-width:500px;
    padding:12px;
    border:2px solid #2e7d32;
    border-radius:8px;
    font-size:16px;
    margin-bottom:30px;
}

/* Products */

.products{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.product-card{
    background:#fff;
    padding:20px;
    border-radius:12px;
    box-shadow:0 5px 15px rgba(0,0,0,0.15);
    transition:0.3s;
}

.product-card:hover{
    transform:translateY(-5px);
}

.product-card img{
    width:100%;
    height:180px;
    object-fit:cover;
    border-radius:10px;
}

.product-card h3{
    margin:15px 0 10px;
    color:#2e7d32;
}

.product-card p{
    margin-bottom:15px;
    font-size:18px;
}

/* Buttons */

button{
    background:#2e7d32;
    color:white;
    border:none;
    padding:12px 20px;
    border-radius:8px;
    cursor:pointer;
    font-size:16px;
    transition:0.3s;
}

button:hover{
    background:#1b5e20;
}

/* Footer */

footer{
    background:#1b5e20;
    color:#fff;
    text-align:center;
    padding:20px;
    margin-top:40px;
}

/* Responsive */

@media(max-width:768px){

header{
    flex-direction:column;
    text-align:center;
}

nav{
    margin-top:15px;
}

nav a{
    display:block;
    margin:8px 0;
}

#searchBox{
    width:95%;
}

.product-card img{
    height:160px;
}

button{
    width:100%;
}

}
