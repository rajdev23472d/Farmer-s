/* =====================================
   Farmer's App - Dashboard CSS
   Volume 1
===================================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f4f7f4;
}

/* Header */

header{
    background:#2e7d32;
    color:#fff;
    padding:15px 30px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

header h1{
    font-size:30px;
}

nav a{
    color:#fff;
    text-decoration:none;
    margin-left:20px;
    font-weight:bold;
}

nav a:hover{
    color:#ffd54f;
}

/* Welcome */

.welcome{
    text-align:center;
    padding:40px 20px;
}

.welcome h2{
    color:#2e7d32;
    margin-bottom:10px;
}

/* Dashboard Cards */

.dashboard-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
    padding:30px;
}

.card{
    background:#fff;
    padding:25px;
    border-radius:12px;
    text-align:center;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
    transition:.3s;
}

.card:hover{
    transform:translateY(-8px);
}

.card h3{
    color:#2e7d32;
    margin-bottom:10px;
}

/* Profile */

.profile{
    display:flex;
    justify-content:center;
    padding:40px;
}

.profile-card{
    width:420px;
    background:#fff;
    padding:30px;
    border-radius:15px;
    text-align:center;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
}

.profile-card img{
    width:120px;
    height:120px;
    border-radius:50%;
    margin-bottom:15px;
}

.profile-card p{
    margin:10px 0;
}

.profile-card button{
    margin-top:20px;
    padding:12px 20px;
    border:none;
    background:#2e7d32;
    color:white;
    border-radius:8px;
    cursor:pointer;
}

.profile-card button:hover{
    background:#1b5e20;
}

/* Farm Info */

.farm-info{
    padding:30px;
}

.farm-info h2{
    text-align:center;
    margin-bottom:20px;
    color:#2e7d32;
}

/* Footer */

footer{
    background:#1b5e20;
    color:white;
    text-align:center;
    padding:20px;
    margin-top:30px;
}

/* Mobile */

@media(max-width:768px){

header{
    flex-direction:column;
}

nav{
    margin-top:15px;
}

nav a{
    display:block;
    margin:10px 0;
}

.dashboard-grid{
    grid-template-columns:1fr;
}

.profile-card{
    width:100%;
}

}
