/* ===========================
   Farmer's App - Login CSS
   Volume 1
=========================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:linear-gradient(135deg,#2e7d32,#66bb6a);
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
}

.login-container{
    width:100%;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
}

.login-box{
    background:#ffffff;
    width:400px;
    max-width:100%;
    padding:40px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,.2);
}

.login-box h1{
    color:#2e7d32;
    text-align:center;
    margin-bottom:10px;
}

.login-box h2{
    text-align:center;
    margin-bottom:25px;
    color:#444;
}

label{
    display:block;
    margin-top:15px;
    margin-bottom:5px;
    font-weight:bold;
}

input{
    width:100%;
    padding:12px;
    border:1px solid #ccc;
    border-radius:8px;
    font-size:16px;
}

input:focus{
    outline:none;
    border-color:#2e7d32;
}

.remember{
    margin-top:15px;
    display:flex;
    align-items:center;
    gap:10px;
}

button{
    width:100%;
    margin-top:20px;
    padding:14px;
    border:none;
    background:#2e7d32;
    color:white;
    font-size:18px;
    border-radius:8px;
    cursor:pointer;
    transition:.3s;
}

button:hover{
    background:#1b5e20;
}

.login-box p{
    text-align:center;
    margin-top:20px;
}

.login-box a{
    color:#2e7d32;
    text-decoration:none;
    font-weight:bold;
}

.login-box a:hover{
    text-decoration:underline;
}

@media(max-width:480px){

.login-box{
    padding:25px;
}

.login-box h1{
    font-size:28px;
}

.login-box h2{
    font-size:20px;
}

}
