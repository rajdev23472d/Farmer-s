/* =====================================
   Farmer-s App
   gps.css
   Volume 3
===================================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#eef7ee;
    color:#333;
}

/* Header */

header{
    background:#2e7d32;
    color:#fff;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 30px;
}

header h1{
    font-size:28px;
}

nav a{
    color:#fff;
    text-decoration:none;
    margin-left:20px;
    font-weight:bold;
}

nav a:hover{
    color:#ffeb3b;
}

/* GPS Section */

.gps-section{
    padding:40px 20px;
    text-align:center;
}

.gps-card{
    background:#fff;
    max-width:700px;
    margin:auto;
    padding:30px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,.15);
}

.gps-card h2{
    color:#2e7d32;
    margin-bottom:20px;
}

#locationText{
    margin:20px 0;
    font-size:18px;
    color:#444;
}

button{
    background:#2e7d32;
    color:#fff;
    border:none;
    padding:12px 25px;
    border-radius:8px;
    font-size:16px;
    cursor:pointer;
    transition:.3s;
}

button:hover{
    background:#1b5e20;
}

iframe{
    width:100%;
    height:400px;
    border:none;
    border-radius:10px;
    margin-top:20px;
}

/* Footer */

footer{
    background:#1b5e20;
    color:#fff;
    text-align:center;
    padding:20px;
    margin-top:40px;
}

/* Responsive */

@media(max-width:768px){

header{
    flex-direction:column;
}

nav{
    margin-top:15px;
}

nav a{
    display:block;
    margin:10px 0;
}

.gps-card{
    width:95%;
    padding:20px;
}

iframe{
    height:300px;
}

button{
    width:100%;
}

}
